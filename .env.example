# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Teacher access (simple password, no real auth)
VITE_TEACHER_PASSWORD=changeme

# Anthropic (server-side only — never expose in VITE_ prefix)
ANTHROPIC_API_KEY=sk-ant-...

# Twilio SMS (server-side only)
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_FROM_NUMBER=+47xxxxxxxx

# Resend email (server-side only)
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@yourdomain.com
